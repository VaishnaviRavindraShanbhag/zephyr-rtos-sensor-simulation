/*Enable i2c1on the Nucleo F401RE board. Without this Zephyrs might treat the i2C1 as disabled*/
&i2c1 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;
/*typically 100kHz*/

    bme280: bme280@76 {
        compatible = "bosch,bme280";
        reg = <0x76>;
    };

    mpu6050: mpu6050@68 {
        compatible = "invensense,mpu6050";
        reg = <0x68>;
    };
};
